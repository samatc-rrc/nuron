# Postgres connection string (Neon via Vercel Marketplace).
# Vercel injects this automatically in deployed environments after you connect
# a Neon database. For local dev, copy this file to .env.local and fill it in.
DATABASE_URL="postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Password for the /admin dashboard. Choose a strong value.
ADMIN_PASSWORD="change-me-to-a-strong-password"
